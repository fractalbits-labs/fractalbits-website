---
import BaseLayout from './BaseLayout.astro';
import { defaultLang } from '../i18n';
import type { Lang } from '../i18n';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  author?: string;
  tags?: string[];
  image?: string;
  lang?: Lang;
}

const { title, description, pubDate, author, tags, image, lang = defaultLang } = Astro.props;

const dateLocale = lang === 'zh' ? 'zh-CN' : 'en-US';
const formattedDate = pubDate.toLocaleDateString(dateLocale, {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<BaseLayout title={`${title} | ${lang === 'zh' ? '分形智存博客' : 'FractalBits Blog'}`} description={description} image={image} lang={lang}>
  <article class="max-w-3xl mx-auto px-4 py-16">
    <header class="mb-10">
      <div class="flex items-center gap-3 mb-4 font-mono text-xs uppercase tracking-wider text-gray-500">
        <time datetime={pubDate.toISOString()}>{formattedDate}</time>
        {tags && tags.length > 0 && (
          <>
            <span class="text-gray-300">/</span>
            <span class="text-primary-700">{tags[0]}</span>
          </>
        )}
      </div>
      <h1 class="text-4xl font-semibold tracking-tight text-gray-900 mb-4">{title}</h1>
      <p class="text-xl text-gray-600">{description}</p>
    </header>
    <div class="prose prose-lg max-w-none prose-headings:text-gray-900 prose-a:text-primary-600 prose-code:text-primary-700 prose-code:bg-gray-100 prose-code:px-1 prose-code:py-0.5 prose-code:rounded">
      <slot />
    </div>
    <footer class="mt-12 pt-6 border-t border-gray-200">
      <div class="flex items-center gap-2 text-sm text-gray-500">
        {author && (
          <>
            <span>{author}</span>
            <span>|</span>
          </>
        )}
        <time datetime={pubDate.toISOString()}>{formattedDate}</time>
      </div>
    </footer>
  </article>
</BaseLayout>
