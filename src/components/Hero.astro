---
import { useTranslations, defaultLang } from '../i18n';
import type { Lang } from '../i18n';

interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
---

<section class="relative bg-gradient-to-b from-slate-100/80 to-transparent border-b border-slate-200/70">
  <div
    class="absolute inset-0 bg-dot-grid [mask-image:linear-gradient(to_bottom,black_20%,transparent_85%)]"
    aria-hidden="true"
  >
  </div>
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 pb-16 md:pt-28 md:pb-20">
    <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-center">
      <!-- Copy -->
      <div class="lg:col-span-7">
        <a
          href="https://github.com/fractalbits-labs/fractalbits"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-3 py-1 mb-6 text-xs font-medium text-gray-600 border border-gray-300 rounded-full bg-white hover:border-gray-400 hover:text-gray-900 transition-colors"
        >
          <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
          {t('hero.badge')}
        </a>

        <h1 class="text-4xl md:text-5xl font-semibold tracking-tight text-gray-900 mb-6 text-balance">
          {t('hero.title.prefix')}
          <span class="text-primary-700 whitespace-nowrap"> {t('hero.title.highlight')}</span>
          {t('hero.title.suffix')}
        </h1>

        <p class="text-lg text-gray-600 leading-relaxed mb-8 max-w-xl" set:html={t('hero.description').replace(/<strong>/g, '<strong class="text-gray-900 font-medium">')}></p>

        <div class="flex flex-wrap gap-3">
          <a
            href="https://github.com/fractalbits-labs/fractalbits"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center px-5 py-2.5 text-sm font-medium rounded-lg text-white bg-primary-600 hover:bg-primary-700 transition-colors"
          >
            {t('hero.cta.start')}
          </a>
          <a
            href="https://github.com/fractalbits-labs/fractalbits/tree/main/docs"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center px-5 py-2.5 text-sm font-medium rounded-lg text-gray-700 bg-white border border-gray-300 hover:bg-gray-50 hover:border-gray-400 transition-colors"
          >
            {t('hero.cta.docs')}
          </a>
        </div>
      </div>

      <!-- Terminal -->
      <div class="lg:col-span-5 rounded-xl bg-slate-900 border border-slate-800 shadow-xl shadow-slate-900/10 overflow-hidden">
        <div class="flex items-center px-4 py-3 border-b border-slate-800">
          <div class="flex gap-1.5">
            <span class="w-2.5 h-2.5 rounded-full bg-slate-700"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-slate-700"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-slate-700"></span>
          </div>
          <span class="ml-4 text-xs text-slate-500 font-mono">us-west-2</span>
        </div>
        <pre class="p-5 text-[13px] leading-6 font-mono overflow-x-auto"><code><span class="text-slate-500">$</span> <span class="text-slate-100">just deploy create-vpc \</span>
<span class="text-slate-100">    --template perf_demo --with-bench</span>
<span class="text-emerald-400">✓</span> <span class="text-slate-400">cluster deployed in under 5 minutes</span>

<span class="text-slate-500"># benchmark — 4 KiB objects, single bucket</span>
<span class="text-emerald-400">GET</span>  <span class="text-slate-100">982,552 Obj/s</span>   <span class="text-slate-400">P99 5.3 ms</span>
<span class="text-sky-400">PUT</span>  <span class="text-slate-100">248,545 Obj/s</span>   <span class="text-slate-400">avg 6.6 ms</span></code></pre>
      </div>
    </div>

    <!-- Stats -->
    <div class="mt-16 pt-10 border-t border-gray-200 grid grid-cols-3 max-w-3xl gap-4">
      <div>
        <div class="font-mono text-2xl sm:text-3xl font-semibold text-gray-900">~1M</div>
        <div class="mt-1 font-mono text-[11px] uppercase tracking-wider text-gray-500">{t('hero.stat.iops')}</div>
      </div>
      <div>
        <div class="font-mono text-2xl sm:text-3xl font-semibold text-gray-900">~5ms</div>
        <div class="mt-1 font-mono text-[11px] uppercase tracking-wider text-gray-500">{t('hero.stat.latency')}</div>
      </div>
      <div>
        <div class="font-mono text-2xl sm:text-3xl font-semibold text-gray-900">&lt;5min</div>
        <div class="mt-1 font-mono text-[11px] uppercase tracking-wider text-gray-500">{t('hero.stat.deploy')}</div>
      </div>
    </div>
  </div>
</section>

<style>
  .text-balance {
    text-wrap: balance;
  }
</style>
