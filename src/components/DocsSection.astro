---
import { useTranslations, defaultLang } from '../i18n';
import type { Lang } from '../i18n';

interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);

const docs = [
  {
    href: 'https://github.com/fractalbits-labs/fractalbits/blob/main/docs/internals/ARCHITECTURE.md',
    title: t('docs.architecture'),
    description: t('docs.architecture.desc'),
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />',
  },
  {
    href: 'https://github.com/fractalbits-labs/fractalbits/blob/main/docs/S3_API_COMPATIBILITY.md',
    title: t('docs.s3api'),
    description: t('docs.s3api.desc'),
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />',
  },
  {
    href: 'https://github.com/fractalbits-labs/fractalbits/blob/main/docs/ROADMAP.md',
    title: t('docs.roadmap'),
    description: t('docs.roadmap.desc'),
    icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />',
  },
];
---

<section class="py-16 bg-white border-t border-gray-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <p class="font-mono text-xs font-semibold text-primary-700 uppercase tracking-widest mb-3">
        {t('docs.eyebrow')}
      </p>
      <h2 class="text-3xl md:text-4xl font-semibold tracking-tight text-gray-900 mb-4">{t('docs.title')}</h2>
      <p class="max-w-2xl mx-auto text-lg text-gray-600">
        {t('docs.description')}
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      {docs.map(({ href, title, description, icon }) => (
        <a
          href={href}
          target="_blank"
          rel="noopener noreferrer"
          class="block p-6 bg-slate-50 rounded-xl border border-gray-200 hover:border-primary-300 hover:shadow-sm transition-all duration-200 group"
        >
          <div class="flex items-center mb-3">
            <svg class="w-5 h-5 text-primary-600 mr-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={icon} />
            <h3 class="font-semibold text-gray-900 group-hover:text-primary-600 transition-colors">{title}</h3>
            <svg class="w-4 h-4 ml-auto text-gray-300 group-hover:text-primary-500 group-hover:translate-x-0.5 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </div>
          <p class="text-sm text-gray-600 leading-relaxed">
            {description}
          </p>
        </a>
      ))}
    </div>
  </div>
</section>
