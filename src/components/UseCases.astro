---
import { useTranslations, defaultLang } from '../i18n';
import type { Lang } from '../i18n';

interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);

const scenarios = [
  {
    key: 'ai',
    icon: 'chip',
    title: t('usecases.ai.title'),
    problem: t('usecases.ai.problem'),
    solution: t('usecases.ai.solution'),
    stats: [
      { value: t('usecases.ai.stat1'), label: t('usecases.ai.stat1label') },
      { value: t('usecases.ai.stat2'), label: t('usecases.ai.stat2label') },
    ],
  },
  {
    key: 'analytics',
    icon: 'chart',
    title: t('usecases.analytics.title'),
    problem: t('usecases.analytics.problem'),
    solution: t('usecases.analytics.solution'),
    stats: [
      { value: t('usecases.analytics.stat1'), label: t('usecases.analytics.stat1label') },
      { value: t('usecases.analytics.stat2'), label: t('usecases.analytics.stat2label') },
    ],
  },
  {
    key: 'metadata',
    icon: 'tree',
    title: t('usecases.metadata.title'),
    problem: t('usecases.metadata.problem'),
    solution: t('usecases.metadata.solution'),
    stats: [
      { value: t('usecases.metadata.stat1'), label: t('usecases.metadata.stat1label') },
      { value: t('usecases.metadata.stat2'), label: t('usecases.metadata.stat2label') },
    ],
  },
  {
    key: 'cost',
    icon: 'dollar',
    title: t('usecases.cost.title'),
    problem: t('usecases.cost.problem'),
    solution: t('usecases.cost.solution'),
    stats: [
      { value: t('usecases.cost.stat1'), label: t('usecases.cost.stat1label') },
      { value: t('usecases.cost.stat2'), label: t('usecases.cost.stat2label') },
    ],
  },
];

const icons: Record<string, string> = {
  chip: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 7h10v10H7V7z" />',
  chart: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3v18h18M7 14l3-3 3 3 5-6" />',
  tree: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h6m-6 6h10m-10 6h6M4 4v16" />',
  dollar: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-10c1.11 0 2.08.402 2.599 1M12 8V6m0 12v-2m0 2c-1.11 0-2.08-.402-2.599-1" />',
};
---

<section id="use-cases" class="py-16 bg-white border-y border-gray-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <p class="font-mono text-xs font-semibold text-primary-700 uppercase tracking-widest mb-3">
        {t('usecases.eyebrow')}
      </p>
      <h2 class="text-3xl md:text-4xl font-semibold tracking-tight text-gray-900 mb-4">
        {t('usecases.title')}
      </h2>
      <p class="max-w-2xl mx-auto text-lg text-gray-600">
        {t('usecases.description')}
      </p>
    </div>

    <div class="space-y-12 lg:space-y-20">
      {scenarios.map(({ icon, title, problem, solution, stats }, i) => (
        <div class="grid lg:grid-cols-2 gap-8 lg:gap-12 items-center">
          <!-- Copy -->
          <div class={i % 2 === 1 ? 'lg:order-2' : ''}>
            <div class="w-11 h-11 bg-primary-50 border border-primary-100 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={icons[icon]} />
            </div>
            <h3 class="text-xl md:text-2xl font-semibold text-gray-900 mb-3">{title}</h3>
            <p class="text-sm text-gray-500 leading-relaxed mb-3">
              <span class="font-mono text-[11px] uppercase tracking-wider text-gray-400 mr-2">Challenge</span>
              {problem}
            </p>
            <p class="text-base text-gray-700 leading-relaxed">
              <span class="font-mono text-[11px] uppercase tracking-wider text-primary-600 mr-2">FractalBits</span>
              {solution}
            </p>
          </div>

          <!-- Stat card -->
          <div class={i % 2 === 1 ? 'lg:order-1' : ''}>
            <div class="grid grid-cols-2 gap-4">
              {stats.map(({ value, label }) => (
                <div class="bg-slate-50 rounded-xl border border-gray-200 p-6">
                  <div class="font-mono text-2xl sm:text-3xl font-semibold text-gray-900 tabular-nums">{value}</div>
                  <div class="mt-2 text-sm text-gray-600 leading-snug">{label}</div>
                </div>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
