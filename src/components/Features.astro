---
import { useTranslations, defaultLang } from '../i18n';
import type { Lang } from '../i18n';

interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);

const features = [
  {
    title: t('features.iops.title'),
    description: t('features.iops.description'),
    icon: 'rocket',
  },
  {
    title: t('features.atomic.title'),
    description: t('features.atomic.description'),
    icon: 'tree',
  },
  {
    title: t('features.protocol.title'),
    description: t('features.protocol.description'),
    icon: 'switch',
  },
  {
    title: t('features.storage.title'),
    description: t('features.storage.description'),
    icon: 'database',
  },
  {
    title: t('features.scale.title'),
    description: t('features.scale.description'),
    icon: 'scale',
  },
  {
    title: t('features.byoc.title'),
    description: t('features.byoc.description'),
    icon: 'cloud',
  },
];

const icons: Record<string, string> = {
  rocket: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />',
  tree: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h6m-6 6h10m-10 6h6M4 4v16" />',
  switch: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m4-4l4 4m6 4v12m0 0l4-4m-4 4l-4-4" />',
  database: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4" />',
  cloud: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" />',
  scale: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4" />',
};
---

<section id="features" class="py-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <p class="font-mono text-xs font-semibold text-primary-700 uppercase tracking-widest mb-3">
        {t('features.eyebrow')}
      </p>
      <h2 class="text-3xl md:text-4xl font-semibold tracking-tight text-gray-900 mb-4">
        {t('features.title')}
      </h2>
      <p class="max-w-2xl mx-auto text-lg text-gray-600">
        {t('features.description')}
      </p>
    </div>

    <div class="flex flex-wrap justify-center gap-6">
      {features.map(({ title, description, icon }) => (
        <div class="w-full sm:w-[calc(50%-0.75rem)] lg:w-[calc(33.333%-1rem)] relative p-6 bg-white rounded-xl border border-gray-200 hover:border-primary-300 hover:shadow-sm transition-all duration-200">
          <div class="w-11 h-11 bg-primary-50 border border-primary-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={icons[icon]} />
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">{title}</h3>
          <p class="text-gray-600 text-sm leading-relaxed">{description}</p>
        </div>
      ))}
    </div>

    <!-- Tech Stack -->
    <div class="mt-16 pt-16 border-t border-slate-200 text-center">
      <p class="font-mono text-xs font-semibold text-gray-400 uppercase tracking-widest mb-5">{t('features.powered')}</p>
      <div class="flex justify-center items-baseline gap-x-10 gap-y-3 flex-wrap">
        <div class="flex items-baseline gap-2">
          <span class="font-mono font-semibold text-gray-900">{t('features.art')}</span>
          <span class="text-sm text-gray-500">{t('features.art.desc')}</span>
        </div>
        <div class="flex items-baseline gap-2">
          <span class="font-mono font-semibold text-gray-900">{t('features.rust')}</span>
          <span class="text-sm text-gray-500">{t('features.rust.desc')}</span>
        </div>
        <div class="flex items-baseline gap-2">
          <span class="font-mono font-semibold text-gray-900">{t('features.iouring')}</span>
          <span class="text-sm text-gray-500">{t('features.iouring.desc')}</span>
        </div>
      </div>
    </div>
  </div>
</section>
