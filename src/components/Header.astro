---
import { useTranslations, getLocalizedPath, defaultLang } from '../i18n';
import type { Lang } from '../i18n';

interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);

const navLinks = [
  { href: getLocalizedPath('/', lang), label: t('nav.home'), key: '/' },
  { href: getLocalizedPath('/blog', lang), label: t('nav.blog'), key: '/blog' },
  { href: 'https://github.com/fractalbits-labs/fractalbits/tree/main/docs', label: t('nav.docs'), external: true },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-gray-200">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-20">
      <a href={getLocalizedPath('/', lang)} class="inline-flex items-center gap-2 py-2">
        <img src="/logo-icon.png" alt={t('site.brand')} class="h-8 w-auto" />
        <span class="text-lg font-semibold tracking-tight text-gray-900">{t('site.brand')}</span>
      </a>

      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-8">
        {navLinks.map(({ href, label, external }) => (
          <a
            href={href}
            class:list={[
              'text-sm font-medium transition-colors',
              currentPath === href ? 'text-primary-600' : 'text-gray-600 hover:text-gray-900'
            ]}
            {...(external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
          >
            {label}
          </a>
        ))}
        <a
          href="https://github.com/fractalbits-labs/fractalbits"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-3.5 py-1.5 text-sm font-medium text-gray-700 border border-gray-300 rounded-lg hover:border-gray-400 hover:text-gray-900 transition-colors"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          {t('nav.github')}
          <span id="gh-stars" class="hidden items-center gap-1 pl-2 ml-0.5 border-l border-gray-300 font-mono text-xs text-gray-500">
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 16 16">
              <path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.75.75 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z"/>
            </svg>
            <span id="gh-stars-count"></span>
          </span>
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 rounded-md text-gray-600 hover:text-gray-900 hover:bg-gray-100"
        aria-label="Toggle menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile Nav -->
    <div id="mobile-menu" class="hidden md:hidden pb-4">
      {navLinks.map(({ href, label, external }) => (
        <a
          href={href}
          class:list={[
            'block py-2 text-base font-medium transition-colors',
            currentPath === href ? 'text-primary-600' : 'text-gray-600 hover:text-gray-900'
          ]}
          {...(external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
        >
          {label}
        </a>
      ))}
      <a
        href="https://github.com/fractalbits-labs/fractalbits"
        target="_blank"
        rel="noopener noreferrer"
        class="block py-2 text-base font-medium text-gray-600 hover:text-gray-900 transition-colors"
      >
        {t('nav.github')}
      </a>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });

  // GitHub star count (best-effort; hidden if the API is unreachable)
  const STARS_KEY = 'fb-gh-stars';
  const STARS_TTL = 6 * 60 * 60 * 1000;

  async function loadStars() {
    const wrapper = document.getElementById('gh-stars');
    const count = document.getElementById('gh-stars-count');
    if (!wrapper || !count) return;
    try {
      let cached = null;
      try {
        cached = JSON.parse(localStorage.getItem(STARS_KEY) || 'null');
      } catch {}

      let stars = cached && Date.now() - cached.t < STARS_TTL ? cached.n : null;
      if (!stars) {
        const res = await fetch('https://api.github.com/repos/fractalbits-labs/fractalbits');
        if (res.ok) {
          stars = (await res.json()).stargazers_count;
          if (stars) localStorage.setItem(STARS_KEY, JSON.stringify({ n: stars, t: Date.now() }));
        } else if (cached) {
          stars = cached.n; // rate-limited: a stale count beats none
        }
      }
      if (!stars) return;

      count.textContent =
        stars >= 1000 ? `${(stars / 1000).toFixed(1).replace(/\.0$/, '')}k` : String(stars);
      wrapper.classList.remove('hidden');
      wrapper.classList.add('inline-flex');
    } catch {
      // leave hidden
    }
  }
  loadStars();
</script>
